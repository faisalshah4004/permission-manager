{
    "name": "codeflextech/permission-manager",
    "description": "A plug-and-play Roles & Permissions management UI for Laravel using spatie/laravel-permission. Drop it in any project.",
    "version": "1.0.3",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "spatie",
        "permissions",
        "roles",
        "rbac",
        "livewire",
        "tailwind"
    ],
    "authors": [
        {
            "name": "Faisal Shah",
            "email": "faisalshah4004@gmail.com",
            "homepage": "https://www.muhammadfaisalshah.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": ">=11.0",
        "spatie/laravel-permission": ">=6.0",
        "livewire/livewire": ">=3.0"
    },
    "require-dev": {
        "orchestra/testbench": ">=9.0",
        "phpunit/phpunit": ">=11.0"
    },
    "autoload": {
        "psr-4": {
            "CodeFlexTech\\PermissionManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeFlexTech\\PermissionManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeFlexTech\\PermissionManager\\Providers\\PermissionManagerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
